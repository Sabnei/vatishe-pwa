# ==========================================================================
# VATISHE — variables de entorno. Copia este archivo a `.env` y complétalo.
# NUNCA subas el archivo `.env` real al repositorio.
# ==========================================================================

# --- Django ---
SECRET_KEY=cambia-esta-clave-por-una-larga-y-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
SITE_URL=http://localhost:8000

# Token compartido para disparar las tareas programadas por HTTP (cron externo).
CRON_TOKEN=

# --- Base de datos ---
# En local, deja DATABASE_URL vacío para usar SQLite.
# En producción, usa la cadena del pooler de Supabase (Supavisor).
# Puerto 6543 = modo transaction (mantén DB_DISABLE_SERVER_SIDE_CURSORS=True).
# DATABASE_URL=postgresql://USUARIO:CONTRASENA@HOST:6543/postgres
DATABASE_URL=
DB_SSL_REQUIRE=True
DB_DISABLE_SERVER_SIDE_CURSORS=True
DB_CONN_MAX_AGE=60

# --- Supabase Storage (compatible S3) ---
# Deja USE_SUPABASE_STORAGE=False en local para guardar archivos en disco.
USE_SUPABASE_STORAGE=False
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_BUCKET=vatishe
SUPABASE_S3_ENDPOINT_URL=https://TU-PROYECTO.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_URL_EXPIRE=300

# --- Correo (Gmail SMTP con contraseña de aplicación) ---
# Con EMAIL_ENABLED=False los correos se imprimen en consola (desarrollo).
EMAIL_ENABLED=False
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-correo@gmail.com
EMAIL_HOST_PASSWORD=tu-contrasena-de-aplicacion
DEFAULT_FROM_EMAIL=VATISHE <no-reply@vatishe.cr>

# --- Parámetros de negocio ---
MAX_UPLOAD_SIZE_MB=1
PAGINACION_POR_PAGINA=20
